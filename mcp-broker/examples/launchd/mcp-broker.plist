<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  LaunchAgent for mcp-broker. Runs the broker in the background whenever
  the user is logged in.

  Before installing:
    1. Replace every occurrence of USERNAME below with your macOS short
       username (see `whoami`). The README's install snippet does this for
       you with sed.
    2. If `go install` put the binary somewhere other than ~/go/bin, update
       the ProgramArguments path accordingly.

  See docs/launchd.md ("Run as a launchd agent") for install and verify steps.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>dev.agent-tools.mcp-broker</string>

    <!-- The no-open flag (third arg below) suppresses the auto-launched
         dashboard browser tab; under launchd nobody is watching stderr so a
         popped tab is just noise. The dashboard URL is still printed to
         .err.log on every start. -->
    <key>ProgramArguments</key>
    <array>
        <string>/Users/USERNAME/go/bin/mcp-broker</string>
        <string>serve</string>
        <string>--no-open</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>EnvironmentVariables</key>
    <dict>
        <!-- PATH must contain whatever your backend MCP servers need to
             exec. Defaults cover Homebrew on Apple Silicon
             (/opt/homebrew/bin), Homebrew on Intel (/usr/local/bin), the
             official Go tarball layout (/usr/local/go/bin), and ~/go/bin
             (where `go install` drops local-gh-mcp / local-git-mcp). Add
             ~/.asdf/shims or similar if your stdio backends need npx. -->
        <key>PATH</key>
        <string>/Users/USERNAME/go/bin:/opt/homebrew/bin:/usr/local/bin:/usr/local/go/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>

        <!-- Backend MCP servers configured with $VAR-style env references
             (e.g. {"env": {"GITHUB_TOKEN": "$GITHUB_TOKEN"}}) need those
             vars present in the broker's process environment. Shell exports
             in .zshrc/.bashrc don't reach launchd, so add them here. The
             recommended path is to use backends that read host credentials
             from the macOS Keychain (e.g. local-gh-mcp via `gh auth`,
             local-git-mcp via `gh auth setup-git`) so this block stays
             empty. -->
        <!--
        <key>GITHUB_TOKEN</key>
        <string>ghp_...</string>
        -->
    </dict>

    <key>WorkingDirectory</key>
    <string>/Users/USERNAME</string>

    <key>StandardOutPath</key>
    <string>/Users/USERNAME/Library/Logs/mcp-broker.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/USERNAME/Library/Logs/mcp-broker.err.log</string>
</dict>
</plist>
